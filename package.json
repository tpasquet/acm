{
  "name": "acm",
  "private": true,
  "version": "0.0.0",
  "description": "AI Context Manager — monorepo",
  "packageManager": "pnpm@9.0.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "tsup": "^8.0.2"
  }
}
