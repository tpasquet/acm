{
  "name": "@acmjs/cli",
  "version": "0.0.1-alpha.0",
  "description": "ACM command-line interface",
  "keywords": ["ai", "context", "claude", "claude-code", "cli", "sync", "dotfiles", "ai-context", "llm"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "acm": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "test": "vitest run"
  },
  "dependencies": {
    "@acmjs/core": "workspace:*",
    "@acmjs/sources": "workspace:*",
    "@acmjs/targets": "workspace:*",
    "commander": "^12.1.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.1",
    "prompts": "^2.4.2",
    "yaml": "^2.4.2"
  },
  "devDependencies": {
    "@types/prompts": "^2.4.9",
    "typescript": "^5.4.5",
    "tsup": "^8.0.2"
  }
}
